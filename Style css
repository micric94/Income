style.css body {
    font-family: Arial, sans-serif;
    background: #f4f7fa;
    display: flex;
    justify-content: center;
    padding: 30px;
}

.container {
    width: 600px;
    background: white;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
}

h1 {
    text-align: center;
}

.summary {
    display: flex;
    justify-content: space-between;
    margin-bottom: 20px;
}

.summary div {
    text-align: center;
}

.income {
    color: green;
}

.expense {
    color: red;
}

form {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

input, select, button {
    padding: 8px;
    border-radius: 5px;
    border: 1px solid #ccc;
}

button {
    background: #007bff;
    color: white;
    cursor: pointer;
    border: none;
}

button:hover {
    background: #0056b3;
}

#transaction-list {
    list-style: none;
    padding: 0;
    margin-top: 20px;
}

.transaction {
    display: flex;
    justify-content: space-between;
    padding: 10px;
    border-left: 5px solid;
    margin-bottom: 10px;
    background: #f9f9f9;
}

.transaction.income {
    border-color: green;
}

.transaction.expense {
    border-color: red;
}

.filters {
    margin-top: 15px;
    display: flex;
    justify-content: space-between;
}
